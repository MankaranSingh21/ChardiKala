   "translit": "jaachau sant ravaal |1| rahaau |",
   "english": "I yearn for the dust of the feet of the Saints. ||1||Pause||",
   "shabadId": "0TH"
  },
  {
   "gurmukhi": "ਹਰਿ ਨਾਮੁ ਅਪੁਨਾ ਦੇਹੁ ॥",
   "translit": "har naam apunaa dehu |",
   "english": "Please bless me with Your Name, Lord.",
   "shabadId": "0TH"
  },

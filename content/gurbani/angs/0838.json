{
 "ang": 838,
 "lines": [
  {
   "gurmukhi": "ਦੀਨਾ ਨਾਥ ਦਇਆਲ ਮੇਰੇ ਸੁਆਮੀ ਦੀਨਾ ਨਾਥ ਦਇਆਲ ॥",
   "translit": "deenaa naath deaal mere suaamee deenaa naath deaal |",
   "english": "O Merciful Master of the meek, You are my Lord and Master, O Merciful Master of the meek.",
   "shabadId": "0TH"
  },
  {
   "gurmukhi": "ਕਰਿ ਦਇਆ ਲੇਹੁ ਲੜਿ ਲਾਇ ॥",
   "translit": "kar deaa lehu larr laae |",
   "english": "Be Merciful, and attach me to the hem of Your robe.",
   "shabadId": "0TH"
  },
  {
   "gurmukhi": "ਨਾਨਕਾ ਨਾਮੁ ਧਿਆਇ ॥੧॥",
   "translit": "naanakaa naam dhiaae |1|",
   "english": "Nanak meditates on the Naam, the Name of the Lord. ||1||",
   "shabadId": "0TH"
  },
  {
   "gurmukhi": "ਤਮ ਅਗਿਆਨ ਮੋਹਤ ਘੂਪ ॥",
